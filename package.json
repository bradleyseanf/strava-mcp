{
  "name": "@r-huijts/strava-mcp-server",
  "version": "1.2.1",
  "description": "Private Strava MCP server for ChatGPT Custom Apps",
  "mcpName": "com.bradleyseanf.strava-coach",
  "repository": {
    "type": "git", 
    "url": "https://github.com/bradleyseanf/strava-mcp"
  },
  "main": "dist/server.js",
  "bin": {
    "strava-mcp-server": "./dist/server.js"
  },
  "type": "module",
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "lint": "eslint . --ext .ts",
    "setup-auth": "tsx scripts/setup-auth.ts",
    "reset-strava": "tsx scripts/reset-strava.ts",
    "test": "vitest run",
    "test:api": "RUN_API_TESTS=true vitest run tests/getActivityStreams.api.test.ts",
    "test:mcp": "tsx scripts/test-mcp-endpoint.ts",
    "security-check": "tsx scripts/security-check.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "strava",
    "llm",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.3.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "open": "^10.1.0",
    "helmet": "^8.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.1",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^2.1.8"
  }
}
